    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nall_duct_system_names = IN[0]\r\nall_systems = IN[1]\r\nall_system_names = IN[2]\r\n\r\nvalid_system = []\r\nnames = []\r\n\r\nfor name, system in zip(all_system_names, all_systems):\r\n    if name in all_duct_system_names:\r\n        names.append(name)\r\n        valid_system.append(system)\r\n\r\n\r\nOUT = names, valid_system",
