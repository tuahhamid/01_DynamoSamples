      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "data;\n\nequipment = data[0];\nductSystems = data[1];\n\n// duct system names\nductSystemNames = Revit.Elements.Element.GetParameterValueByName(ductSystems, \"System Name\");\n\n// get system names from mech equipment\nmechSystemNames = Revit.Elements.Element.GetParameterValueByName(equipment, \"System Name\");\nmechSystemNamesList = DSCore.String.Split(mechSystemNames, [\",\"]);\n\n// join duct and mech system names\nallSystemNames = List.Join([ductSystemNames, mechSystemNamesList]);\n\n//output\nequipment;\nallSystemNames;"
    },
