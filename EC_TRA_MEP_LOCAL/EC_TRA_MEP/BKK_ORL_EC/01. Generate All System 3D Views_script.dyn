    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n\r\nelements = IN[0]\r\nelement_system_names = IN[1]\r\navailable_names = IN[2]\r\n\r\nfound_list = []\r\nnot_found_indx = []\r\nnot_found_list = []\r\n\r\nfor names, ele in zip(element_system_names, elements):\r\n\tfound_sublist = []\r\n\tfor name in names:\r\n\t\tif name in available_names:\r\n\t\t\tfound_sublist.append(name)\r\n\tfound_list.append(found_sublist)\r\n\r\nfor indx, l in enumerate(found_list):\r\n    if l:\r\n        continue\r\n    not_found_indx.append(indx)\r\n    \r\nfor indx in not_found_indx:\r\n    not_found_list.append(elements[indx])\r\n\r\nOUT = found_list, not_found_indx, not_found_list",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "8460b005872841b187233b1650213c7f",
      "NodeType": "PythonScriptNode",
