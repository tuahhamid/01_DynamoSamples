    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nelement_system_names = IN[0]\r\nelements = IN[1]\r\nvalid_system_names = IN[2]\r\n\r\nbool_flag = []\r\nvalid_elements = []\r\ninvalid_elements = []\r\n\r\nfor name, ele in zip(element_system_names, elements):\r\n    if name in valid_system_names:\r\n        bool_flag.append(True)\r\n        valid_elements.append(ele)\r\n    else:\r\n        bool_flag.append(False)\r\n        invalid_elements.append(ele)\r\n\r\nOUT = bool_flag, valid_elements, invalid_elements",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "26cb6f238a4b418b9d457c0b927be7cf",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "5df58f1d2ae945669baa2111b0179057",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
