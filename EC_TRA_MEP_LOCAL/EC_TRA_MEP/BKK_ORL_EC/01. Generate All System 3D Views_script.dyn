      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nelements = IN[0]\r\nelement_ids = IN[1]\r\n\r\nvalid_elements = []\r\nvalid_ids = []\r\ninvalid_elements = []\r\n\r\nfor id, ele in zip(element_ids, elements):\r\n    if id:\r\n        valid_elements.append(ele)\r\n        valid_ids.append(id)\r\n    else:\r\n        invalid_elements.append(ele)\r\n\r\nOUT = valid_elements, valid_ids, invalid_elements",
      "Engine": "CPython3",
