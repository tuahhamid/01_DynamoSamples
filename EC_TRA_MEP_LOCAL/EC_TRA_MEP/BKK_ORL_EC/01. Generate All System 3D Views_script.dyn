      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Load the Python Standard and DesignScript Libraries\r\nimport sys\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nduct_system_elements  = IN[0]\r\nduct_system_names  = IN[1]\r\nmech_equipment_elements =IN[2]\r\nmech_equipment_system_names =IN[3]\r\n\r\nfound_duct_systems = []\r\nnot_found_names = []\r\nnot_found_mech_equipments = []\r\nindx_check = []\r\n\r\nfor name, element in zip(mech_equipment_system_names, mech_equipment_elements):\r\n    found_sublist = []\r\n    not_found_sublist = []\r\n    for n in name:\r\n        if n in duct_system_names:\r\n            index = duct_system_names.index(n)\r\n            indx_check.append(index)\r\n            match_ele = duct_system_elements[index]\r\n            found_sublist.append(match_ele)\r\n        else:\r\n            not_found_sublist.append(n)\r\n            not_found_mech_equipments.append(element)\r\n    found_duct_systems.append(found_sublist)\r\n    not_found_names.append(not_found_sublist)\r\n\r\n\r\nOUT = (found_duct_systems, not_found_names, set(not_found_mech_equipments), indx_check)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "fb149b20bdc9491ba69bae9b6a819031",
      "NodeType": "PythonScriptNode",
      "Inputs": [
