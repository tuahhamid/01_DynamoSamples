      "Code": "// generate schedule if model contains invalid elements\ninvalidElements;\n\n//is empty\nisEmpty = List.IsEmpty(invalidElements);\nisNull = DSCore.Object.IsNull(invalidElements);\n\n// if list contains invalid elements,\n//\n// create schedule\nallowCatName = [Imperative]{\nif (isEmpty == false || isEmpty == null)\n\treturn \"Mechanical Equipment\";\nelse\n\treturn List.Empty;\n};\n\n//output\nallowCatName;"
    },
